[{"role":"user","content":"في ملف car.html يوجد خطأ وهي لعبة ما تشتغل يعني زر بدأ لا يعمل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة سباق السيارات 3D</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: Arial, sans-serif; }\n  canvas { display: block; width: 100vw; height: 100vh; }\n  #ui {\n    position: fixed; top: 0; left: 0; right: 0;\n    display: flex; justify-content: space-between; align-items: flex-start;\n    padding: 15px; pointer-events: none; z-index: 10;\n  }\n  .stat-box {\n    background: rgba(0,0,0,0.7);\n    border: 2px solid #00ffff;\n    border-radius: 10px;\n    padding: 10px 18px;\n    color: #fff;\n    text-align: center;\n    min-width: 100px;\n  }\n  .stat-box .label { font-size: 11px; color: #00ffff; text-transform: uppercase; letter-spacing: 1px; }\n  .stat-box .value { font-size: 26px; font-weight: bold; color: #fff; }\n  #lap-msg {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);\n    font-size: 48px; font-weight: bold; color: #ffff00;\n    text-shadow: 0 0 20px #ff8800, 0 0 40px #ff4400;\n    display: none; z-index: 20;\n    animation: pulse 0.5s ease-in-out infinite alternate;\n  }\n  @keyframes pulse { from { transform: translate(-50%,-50%) scale(1); } to { transform: translate(-50%,-50%) scale(1.1); } }\n  #start-screen {\n    position: fixed; inset: 0;\n    background: radial-gradient(ellipse at center, #0a0a2e 0%, #000 100%);\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    z-index: 100; color: #fff;\n  }\n  #start-screen h1 {\n    font-size: 52px; font-weight: 900;\n    background: linear-gradient(135deg, #00ffff, #ff00ff, #ffff00);\n    -webkit-background-clip: text; -webkit-text-fill-color: transparent;\n    margin-bottom: 10px;\n    animation: titleGlow 2s ease-in-out infinite alternate;\n  }\n  @keyframes titleGlow {\n    from { filter: drop-shadow(0 0 10px #00ffff); }\n    to { filter: drop-shadow(0 0 30px #ff00ff); }\n  }\n  #start-screen p { color: #aaa; margin-bottom: 40px; font-size: 16px; }\n  .start-btn {\n    padding: 18px 60px; font-size: 22px; font-weight: bold;\n    background: linear-gradient(135deg, #00ffff, #0088ff);\n    color: #000; border: none; border-radius: 50px;\n    cursor: pointer; letter-spacing: 2px;\n    box-shadow: 0 0 30px rgba(0,200,255,0.6);\n    transition: transform 0.2s, box-shadow 0.2s;\n  }\n  .start-btn:hover { transform: scale(1.05); box-shadow: 0 0 50px rgba(0,200,255,0.9); }\n  .car-preview { font-size: 80px; margin-bottom: 20px; animation: bounce 1s ease-in-out infinite alternate; }\n  @keyframes bounce { from { transform: translateY(0); } to { transform: translateY(-15px); } }\n  #countdown {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);\n    font-size: 120px; font-weight: 900; color: #ffff00;\n    text-shadow: 0 0 40px #ff8800;\n    display: none; z-index: 50;\n  }\n  #finish-screen {\n    position: fixed; inset: 0;\n    background: rgba(0,0,0,0.85);\n    display: none; flex-direction: column; align-items: center; justify-content: center;\n    z-index: 100; color: #fff;\n  }\n  #finish-screen h2 { font-size: 60px; color: #ffff00; text-shadow: 0 0 30px #ff8800; margin-bottom: 20px; }\n  #finish-screen .time-display { font-size: 36px; color: #00ffff; margin-bottom: 30px; }\n  .nitro-bar-container {\n    position: fixed; bottom: 160px; left: 50%; transform: translateX(-50%);\n    width: 200px; z-index: 10; pointer-events: none;\n  }\n  .nitro-label { color: #ff8800; font-size: 12px; text-align: center; letter-spacing: 2px; margin-bottom: 4px; }\n  .nitro-bar-bg { background: rgba(0,0,0,0.6); border: 2px solid #ff8800; border-radius: 10px; height: 16px; overflow: hidden; }\n  .nitro-bar-fill { height: 100%; background: linear-gradient(90deg, #ff4400, #ffaa00, #ffff00); border-radius: 8px; transition: width 0.1s; }\n  #mobile-controls {\n    position: fixed; bottom: 0; left: 0; right: 0;\n    height: 150px;\n    display: flex; justify-content: space-between; align-items: center;\n    padding: 10px 20px;\n    z-index: 15;\n    pointer-events: none;\n  }\n  .ctrl-group { display: flex; gap: 10px; pointer-events: all; }\n  .ctrl-btn {\n    width: 65px; height: 65px;\n    border-radius: 50%;\n    border: 3px solid rgba(255,255,255,0.5);\n    background: rgba(255,255,255,0.15);\n    backdrop-filter: blur(5px);\n    color: #fff;\n    font-size: 28px;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer;\n    user-select: none;\n    -webkit-user-select: none;\n    touch-action: none;\n    transition: background 0.1s;\n    box-shadow: 0 0 15px rgba(0,200,255,0.3);\n  }\n  .ctrl-btn:active, .ctrl-btn.pressed {\n    background: rgba(0,200,255,0.4);\n    border-color: #00ffff;\n    box-shadow: 0 0 25px rgba(0,200,255,0.7);\n  }\n  .ctrl-btn.gas { background: rgba(0,255,100,0.2); border-color: rgba(0,255,100,0.6); }\n  .ctrl-btn.gas.pressed { background: rgba(0,255,100,0.5); }\n  .ctrl-btn.brake { background: rgba(255,50,50,0.2); border-color: rgba(255,50,50,0.6); }\n  .ctrl-btn.brake.pressed { background: rgba(255,50,50,0.5); }\n  #nitro-btn {\n    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);\n    width: 80px; height: 80px; border-radius: 50%;\n    background: rgba(255,140,0,0.25); border: 3px solid #ff8800;\n    color: #ffaa00; font-size: 14px; font-weight: bold;\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    cursor: pointer; z-index: 15; touch-action: none;\n    box-shadow: 0 0 20px rgba(255,140,0,0.4);\n    user-select: none; -webkit-user-select: none;\n  }\n  #nitro-btn.pressed { background: rgba(255,140,0,0.6); box-shadow: 0 0 40px rgba(255,200,0,0.9); }\n  #nitro-btn span { font-size: 24px; }\n</style>\n</head>\n<body>\n\n<div id=\"start-screen\">\n  <div class=\"car-preview\">🏎️</div>\n  <h1>سباق السيارات 3D</h1>\n  <p>اختبر مهاراتك في قيادة السيارات الخارقة!</p>\n  <button class=\"start-btn\" id=\"startBtn\">🚀 ابدأ السباق</button>\n</div>\n\n<div id=\"countdown\"></div>\n<div id=\"lap-msg\"></div>\n\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div class=\"stat-box\">\n    <div class=\"label\">اللفة</div>\n    <div class=\"value\" id=\"lap-display\">1 / 3</div>\n  </div>\n  <div class=\"stat-box\">\n    <div class=\"label\">الوقت</div>\n    <div class=\"value\" id=\"time-display\">0:00.0</div>\n  </div>\n  <div class=\"stat-box\">\n    <div class=\"label\">أفضل وقت</div>\n    <div class=\"value\" id=\"best-display\">--:--</div>\n  </div>\n</div>\n\n<canvas id=\"minimapCanvas\" style=\"position:fixed;bottom:160px;left:20px;width:120px;height:120px;border:2px solid #00ffff;border-radius:10px;background:rgba(0,0,0,0.7);z-index:10;\"></canvas>\n<canvas id=\"speedCanvas\" style=\"position:fixed;bottom:160px;right:20px;width:130px;height:130px;z-index:10;\"></canvas>\n\n<div class=\"nitro-bar-container\">\n  <div class=\"nitro-label\">⚡ نيترو</div>\n  <div class=\"nitro-bar-bg\"><div class=\"nitro-bar-fill\" id=\"nitro-fill\" style=\"width:100%\"></div></div>\n</div>\n\n<div id=\"mobile-controls\">\n  <div class=\"ctrl-group\">\n    <button class=\"ctrl-btn\" id=\"btn-left\">◀</button>\n    <button class=\"ctrl-btn\" id=\"btn-right\">▶</button>\n  </div>\n  <div class=\"ctrl-group\" style=\"flex-direction:column;gap:10px;\">\n    <button class=\"ctrl-btn gas\" id=\"btn-gas\">▲</button>\n    <button class=\"ctrl-btn brake\" id=\"btn-brake\">▼</button>\n  </div>\n</div>\n\n<button id=\"nitro-btn\">\n  <span>⚡</span>نيترو\n</button>\n\n<div id=\"finish-screen\">\n  <h2>🏆 انتهى السباق!</h2>\n  <div class=\"time-display\" id=\"finish-time\"></div>\n  <button class=\"start-btn\" id=\"restartBtn\">🔄 العب مجدداً</button>\n</div>\n\n<script>\n// ===== CANVAS SETUP =====\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\nconst mmCanvas = document.getElementById('minimapCanvas');\nconst mmCtx = mmCanvas.getContext('2d');\nconst spCanvas = document.getElementById('speedCanvas');\nconst spCtx = spCanvas.getContext('2d');\n\nmmCanvas.width = 120; mmCanvas.height = 120;\nspCanvas.width = 130; spCanvas.height = 130;\n\nfunction resize() {\n  canvas.width = window.innerWidth;\n  canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// ===== TRACK =====\nconst TRACK_POINTS = [\n  {x:0,   z:0},\n  {x:200, z:-50},\n  {x:400, z:-80},\n  {x:600, z:-30},\n  {x:750, z:100},\n  {x:700, z:250},\n  {x:550, z:350},\n  {x:400, z:380},\n  {x:200, z:350},\n  {x:50,  z:250},\n  {x:-100,z:200},\n  {x:-200,z:100},\n  {x:-180,z:-50},\n  {x:-100,z:-120},\n  {x:-50, z:-80}\n];\nconst TRACK_WIDTH = 60;\nconst TOTAL_LAPS = 3;\n\nfunction catmullRom(p0, p1, p2, p3, t) {\n  const t2 = t * t, t3 = t2 * t;\n  return {\n    x: 0.5 * ((2*p1.x) + (-p0.x+p2.x)*t + (2*p0.x-5*p1.x+4*p2.x-p3.x)*t2 + (-p0.x+3*p1.x-3*p2.x+p3.x)*t3),\n    z: 0.5 * ((2*p1.z) + (-p0.z+p2.z)*t + (2*p0.z-5*p1.z+4*p2.z-p3.z)*t2 + (-p0.z+3*p1.z-3*p2.z+p3.z)*t3)\n  };\n}\n\nfunction buildTrack() {\n  const pts = [];\n  const n = TRACK_POINTS.length;\n  const steps = 20;\n  for (let i = 0; i < n; i++) {\n    const p0 = TRACK_POINTS[(i - 1 + n) % n];\n    const p1 = TRACK_POINTS[i];\n    const p2 = TRACK_POINTS[(i + 1) % n];\n    const p3 = TRACK_POINTS[(i + 2) % n];\n    for (let s = 0; s < steps; s++) {\n      pts.push(catmullRom(p0, p1, p2, p3, s / steps));\n    }\n  }\n  return pts;\n}\n\nconst trackPoints = buildTrack();\n\n// ===== GAME STATE =====\nlet gameRunning = false;\nlet game"}]