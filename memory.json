[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; overflow: hidden; font-family: Arial, sans-serif; }\n#gameCanvas { display: block; width: 100vw; height: 100vh; }\n#ui {\n  position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10;\n}\n#healthBars {\n  display: flex; justify-content: space-between; align-items: flex-start;\n  padding: 15px 20px;\n}\n.playerHUD {\n  display: flex; flex-direction: column; align-items: center; gap: 5px;\n}\n.playerName {\n  color: #fff; font-size: 14px; font-weight: bold;\n  text-shadow: 0 0 10px rgba(255,255,255,0.8);\n}\n.healthBarBg {\n  width: 200px; height: 20px; background: #333;\n  border: 2px solid #666; border-radius: 10px; overflow: hidden;\n}\n.healthBar {\n  height: 100%; border-radius: 8px; transition: width 0.3s;\n}\n#p1Health { background: linear-gradient(90deg, #ff4444, #ff8800); }\n#p2Health { background: linear-gradient(90deg, #4444ff, #00aaff); }\n.powerBar {\n  width: 200px; height: 10px; background: #333;\n  border: 1px solid #666; border-radius: 5px; overflow: hidden;\n}\n.powerFill {\n  height: 100%; border-radius: 4px; transition: width 0.2s;\n}\n#p1Power { background: linear-gradient(90deg, #ffaa00, #ffff00); }\n#p2Power { background: linear-gradient(90deg, #aa00ff, #ff00ff); }\n#timer {\n  position: fixed; top: 15px; left: 50%; transform: translateX(-50%);\n  color: #fff; font-size: 32px; font-weight: bold;\n  text-shadow: 0 0 20px #ff8800;\n  background: rgba(0,0,0,0.5); padding: 5px 20px; border-radius: 10px;\n  border: 2px solid #ff8800; z-index: 10;\n}\n#roundText {\n  position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);\n  color: #fff; font-size: 60px; font-weight: bold;\n  text-shadow: 0 0 30px #ff8800;\n  z-index: 20; display: none;\n  animation: popIn 0.5s ease;\n}\n@keyframes popIn {\n  0% { transform: translate(-50%, -50%) scale(0); }\n  70% { transform: translate(-50%, -50%) scale(1.2); }\n  100% { transform: translate(-50%, -50%) scale(1); }\n}\n#controls {\n  position: fixed; bottom: 0; left: 0; width: 100%;\n  display: flex; justify-content: space-between; align-items: flex-end;\n  padding: 15px; z-index: 10; pointer-events: none;\n}\n.controlGroup { pointer-events: all; }\n.dpad {\n  display: grid; grid-template-columns: repeat(3, 55px);\n  grid-template-rows: repeat(3, 55px); gap: 3px;\n}\n.dpad-btn {\n  background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3);\n  border-radius: 10px; color: #fff; font-size: 20px;\n  display: flex; align-items: center; justify-content: center;\n  cursor: pointer; user-select: none; -webkit-user-select: none;\n  transition: background 0.1s;\n  touch-action: none;\n}\n.dpad-btn:active, .dpad-btn.pressed {\n  background: rgba(255,255,255,0.4);\n}\n.dpad-center { background: rgba(255,255,255,0.05); border-color: transparent; }\n.actionBtns {\n  display: grid; grid-template-columns: repeat(2, 65px);\n  grid-template-rows: repeat(2, 65px); gap: 8px;\n}\n.action-btn {\n  border-radius: 50%; border: 3px solid;\n  color: #fff; font-size: 12px; font-weight: bold;\n  display: flex; align-items: center; justify-content: center;\n  cursor: pointer; user-select: none; -webkit-user-select: none;\n  transition: all 0.1s; touch-action: none;\n  flex-direction: column; gap: 2px;\n}\n.action-btn:active, .action-btn.pressed {\n  transform: scale(0.9); filter: brightness(1.5);\n}\n.btn-punch {\n  background: rgba(255,100,0,0.3); border-color: #ff6400;\n  box-shadow: 0 0 15px rgba(255,100,0,0.5);\n}\n.btn-kick {\n  background: rgba(0,150,255,0.3); border-color: #0096ff;\n  box-shadow: 0 0 15px rgba(0,150,255,0.5);\n}\n.btn-special {\n  background: rgba(200,0,255,0.3); border-color: #c800ff;\n  box-shadow: 0 0 15px rgba(200,0,255,0.5);\n}\n.btn-block {\n  background: rgba(0,200,100,0.3); border-color: #00c864;\n  box-shadow: 0 0 15px rgba(0,200,100,0.5);\n}\n.btn-icon { font-size: 22px; }\n.btn-label { font-size: 9px; opacity: 0.8; }\n#jumpBtn {\n  position: fixed; bottom: 200px; right: 20px;\n  width: 60px; height: 60px; border-radius: 50%;\n  background: rgba(255,220,0,0.3); border: 3px solid #ffdc00;\n  color: #fff; font-size: 10px; font-weight: bold;\n  display: flex; align-items: center; justify-content: center;\n  flex-direction: column; cursor: pointer;\n  box-shadow: 0 0 15px rgba(255,220,0,0.5);\n  z-index: 10; touch-action: none; user-select: none;\n}\n#jumpBtn:active { transform: scale(0.9); filter: brightness(1.5); }\n#overlay {\n  position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n  background: rgba(0,0,0,0.85); z-index: 30;\n  display: flex; flex-direction: column; align-items: center; justify-content: center;\n  gap: 20px;\n}\n#overlay h1 {\n  color: #ff8800; font-size: 48px; font-weight: bold;\n  text-shadow: 0 0 30px #ff8800;\n  animation: glow 2s ease-in-out infinite alternate;\n}\n@keyframes glow {\n  from { text-shadow: 0 0 20px #ff8800; }\n  to { text-shadow: 0 0 50px #ff8800, 0 0 80px #ff4400; }\n}\n#overlay p { color: #ccc; font-size: 18px; text-align: center; }\n#startBtn {\n  background: linear-gradient(135deg, #ff8800, #ff4400);\n  color: #fff; border: none; padding: 15px 50px;\n  font-size: 22px; font-weight: bold; border-radius: 30px;\n  cursor: pointer; box-shadow: 0 0 30px rgba(255,136,0,0.6);\n  transition: transform 0.2s;\n}\n#startBtn:hover { transform: scale(1.05); }\n#winScreen {\n  position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n  background: rgba(0,0,0,0.9); z-index: 30;\n  display: none; flex-direction: column; align-items: center; justify-content: center;\n  gap: 20px;\n}\n#winText { color: #ffdd00; font-size: 52px; font-weight: bold; text-align: center; }\n#winSubText { color: #ccc; font-size: 20px; }\n#restartBtn {\n  background: linear-gradient(135deg, #4444ff, #0088ff);\n  color: #fff; border: none; padding: 12px 40px;\n  font-size: 18px; font-weight: bold; border-radius: 25px;\n  cursor: pointer; box-shadow: 0 0 20px rgba(0,136,255,0.6);\n}\n#hitEffect {\n  position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n  pointer-events: none; z-index: 15; display: none;\n}\n#comboText {\n  position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);\n  color: #ffff00; font-size: 40px; font-weight: bold;\n  text-shadow: 0 0 20px #ff8800; z-index: 20;\n  display: none; pointer-events: none;\n}\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div id=\"healthBars\">\n    <div class=\"playerHUD\">\n      <div class=\"playerName\">🔴 المقاتل 1</div>\n      <div class=\"healthBarBg\"><div class=\"healthBar\" id=\"p1Health\" style=\"width:100%\"></div></div>\n      <div class=\"powerBar\"><div class=\"powerFill\" id=\"p1Power\" style=\"width:0%\"></div></div>\n    </div>\n    <div class=\"playerHUD\">\n      <div class=\"playerName\">🔵 المقاتل 2</div>\n      <div class=\"healthBarBg\"><div class=\"healthBar\" id=\"p2Health\" style=\"width:100%\"></div></div>\n      <div class=\"powerBar\"><div class=\"powerFill\" id=\"p2Power\" style=\"width:0%\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"timer\">60</div>\n<div id=\"roundText\">الجولة 1</div>\n<div id=\"comboText\"></div>\n\n<div id=\"controls\">\n  <div class=\"controlGroup\">\n    <div class=\"dpad\">\n      <div></div>\n      <div class=\"dpad-btn\" id=\"btnUp\" ontouchstart=\"dpadPress('up')\" ontouchend=\"dpadRelease('up')\">▲</div>\n      <div></div>\n      <div class=\"dpad-btn\" id=\"btnLeft\" ontouchstart=\"dpadPress('left')\" ontouchend=\"dpadRelease('left')\">◀</div>\n      <div class=\"dpad-center\"></div>\n      <div class=\"dpad-btn\" id=\"btnRight\" ontouchstart=\"dpadPress('right')\" ontouchend=\"dpadRelease('right')\">▶</div>\n      <div></div>\n      <div class=\"dpad-btn\" id=\"btnDown\" ontouchstart=\"dpadPress('down')\" ontouchend=\"dpadRelease('down')\">▼</div>\n      <div></div>\n    </div>\n  </div>\n  <div class=\"controlGroup\">\n    <div class=\"actionBtns\">\n      <div class=\"action-btn btn-punch\" ontouchstart=\"doAction('punch')\">\n        <span class=\"btn-icon\">👊</span><span class=\"btn-label\">لكمة</span>\n      </div>\n      <div class=\"action-btn btn-kick\" ontouchstart=\"doAction('kick')\">\n        <span class=\"btn-icon\">🦵</span><span class=\"btn-label\">ركلة</span>\n      </div>\n      <div class=\"action-btn btn-special\" ontouchstart=\"doAction('special')\">\n        <span class=\"btn-icon\">⚡</span><span class=\"btn-label\">خاص</span>\n      </div>\n      <div class=\"action-btn btn-block\" ontouchstart=\"doAction('block')\" ontouchend=\"releaseBlock()\">\n        <span class=\"btn-icon\">🛡️</span><span class=\"btn-label\">دفاع</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div id=\"jumpBtn\" ontouchstart=\"doAction('jump')\">\n  <span style=\"font-size:22px\">⬆️</span>\n  <span style=\"font-size:9px\">قفز</span>\n</div>\n\n<div id=\"overlay\">\n  <h1>⚔️ القتال 3D ⚔️</h1>\n  <p>لعبة قتال ثلاثية الأبعاد<br>استخدم الأزرار للتحرك والهجوم</p>\n  <button id=\"startBtn\" onclick=\"startGame()\">ابدأ اللعبة</button>\n</div>\n\n<div id=\"winScreen\">\n  <div id=\"winText\">🏆 فوز!</div>\n  <div id=\"winSubText\"></div>\n  <button id=\"restartBtn\" onclick=\"restartGame()\">العب مرة أخرى</button>\n</div>\n\n<canvas id=\"hitEffect\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:15;\"></canvas>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\nconst keys = {};\nwindow.addEventListener('keydown', e => { keys[e.key] = true; });\nwindow.addEventListener('keyup', e => { keys[e.key] = false; });\n\nlet gameRunning = false;\nlet gameTime = 60;\nlet timerInterval;\nlet round = 1;\nlet p1Wins = 0;\nlet p2Wins = 0;\n\nconst GROUND_Y = 0.7;\nconst"}]