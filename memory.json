[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; overflow: hidden; font-family: Arial, sans-serif; }\n#gameCanvas { display: block; width: 100vw; height: 100vh; }\n#ui {\n  position: fixed; top: 0; left: 0; right: 0;\n  display: flex; justify-content: space-between; align-items: flex-start;\n  padding: 10px; pointer-events: none; z-index: 10;\n}\n.health-bar-container {\n  display: flex; flex-direction: column; align-items: center; gap: 4px;\n}\n.health-label { color: #fff; font-size: 12px; font-weight: bold; text-shadow: 1px 1px 2px #000; }\n.health-bar {\n  width: 150px; height: 18px;\n  background: #333; border: 2px solid #fff;\n  border-radius: 9px; overflow: hidden;\n}\n.health-fill {\n  height: 100%; border-radius: 7px;\n  transition: width 0.2s;\n}\n#playerHealth .health-fill { background: linear-gradient(90deg, #00ff44, #44ff00); }\n#enemyHealth .health-fill { background: linear-gradient(90deg, #ff4400, #ff0044); }\n#scoreBoard {\n  position: fixed; top: 10px; left: 50%; transform: translateX(-50%);\n  color: #fff; font-size: 14px; font-weight: bold;\n  text-shadow: 1px 1px 3px #000; text-align: center; pointer-events: none; z-index: 10;\n}\n#roundText {\n  position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);\n  color: #ffdd00; font-size: 48px; font-weight: bold;\n  text-shadow: 2px 2px 8px #000; pointer-events: none; z-index: 20;\n  opacity: 0; transition: opacity 0.5s;\n}\n#controls {\n  position: fixed; bottom: 0; left: 0; right: 0;\n  display: flex; justify-content: space-between; align-items: flex-end;\n  padding: 15px; z-index: 10; pointer-events: none;\n}\n.dpad {\n  display: grid; grid-template-columns: repeat(3, 55px);\n  grid-template-rows: repeat(3, 55px); gap: 4px;\n  pointer-events: all;\n}\n.dpad-btn {\n  background: rgba(255,255,255,0.15);\n  border: 2px solid rgba(255,255,255,0.4);\n  border-radius: 10px; color: #fff;\n  font-size: 20px; cursor: pointer;\n  display: flex; align-items: center; justify-content: center;\n  user-select: none; -webkit-user-select: none;\n  transition: background 0.1s;\n  touch-action: none;\n}\n.dpad-btn:active, .dpad-btn.pressed {\n  background: rgba(255,255,255,0.4);\n}\n.dpad-center { background: rgba(255,255,255,0.05); border-color: transparent; }\n.action-buttons {\n  display: grid; grid-template-columns: repeat(2, 65px);\n  grid-template-rows: repeat(2, 65px); gap: 8px;\n  pointer-events: all;\n}\n.action-btn {\n  border-radius: 50%; border: 3px solid;\n  font-size: 11px; font-weight: bold; color: #fff;\n  cursor: pointer; display: flex; align-items: center;\n  justify-content: center; user-select: none;\n  -webkit-user-select: none; touch-action: none;\n  transition: transform 0.1s, opacity 0.1s;\n  text-align: center; line-height: 1.2;\n}\n.action-btn:active, .action-btn.pressed {\n  transform: scale(0.9); opacity: 0.7;\n}\n#btnPunch {\n  background: rgba(255, 80, 0, 0.7);\n  border-color: #ff5000;\n}\n#btnKick {\n  background: rgba(255, 200, 0, 0.7);\n  border-color: #ffc800;\n}\n#btnBlock {\n  background: rgba(0, 150, 255, 0.7);\n  border-color: #0096ff;\n}\n#btnSpecial {\n  background: rgba(180, 0, 255, 0.7);\n  border-color: #b400ff;\n}\n#gameOver {\n  position: fixed; top: 0; left: 0; right: 0; bottom: 0;\n  background: rgba(0,0,0,0.85);\n  display: none; flex-direction: column;\n  align-items: center; justify-content: center;\n  z-index: 30; color: #fff;\n}\n#gameOver h1 { font-size: 52px; margin-bottom: 20px; text-shadow: 0 0 20px currentColor; }\n#gameOver p { font-size: 20px; margin-bottom: 30px; color: #aaa; }\n#restartBtn {\n  padding: 15px 40px; font-size: 20px; font-weight: bold;\n  background: linear-gradient(135deg, #ff4400, #ff0088);\n  color: #fff; border: none; border-radius: 30px;\n  cursor: pointer; box-shadow: 0 4px 20px rgba(255,68,0,0.5);\n}\n#restartBtn:hover { transform: scale(1.05); }\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div class=\"health-bar-container\" id=\"playerHealth\">\n    <div class=\"health-label\">🥷 اللاعب</div>\n    <div class=\"health-bar\"><div class=\"health-fill\" id=\"playerFill\" style=\"width:100%\"></div></div>\n  </div>\n  <div class=\"health-bar-container\" id=\"enemyHealth\">\n    <div class=\"health-label\">👹 العدو</div>\n    <div class=\"health-bar\"><div class=\"health-fill\" id=\"enemyFill\" style=\"width:100%\"></div></div>\n  </div>\n</div>\n\n<div id=\"scoreBoard\">الجولة: <span id=\"roundNum\">1</span> | انتصارات: <span id=\"wins\">0</span> - <span id=\"losses\">0</span></div>\n\n<div id=\"roundText\">FIGHT!</div>\n\n<div id=\"controls\">\n  <div class=\"dpad\">\n    <div></div>\n    <div class=\"dpad-btn\" id=\"btnUp\">▲</div>\n    <div></div>\n    <div class=\"dpad-btn\" id=\"btnLeft\">◀</div>\n    <div class=\"dpad-center\"></div>\n    <div class=\"dpad-btn\" id=\"btnRight\">▶</div>\n    <div></div>\n    <div class=\"dpad-btn\" id=\"btnDown\">▼</div>\n    <div></div>\n  </div>\n  <div class=\"action-buttons\">\n    <div class=\"action-btn\" id=\"btnPunch\">👊<br>لكمة</div>\n    <div class=\"action-btn\" id=\"btnKick\">🦵<br>ركلة</div>\n    <div class=\"action-btn\" id=\"btnBlock\">🛡️<br>دفاع</div>\n    <div class=\"action-btn\" id=\"btnSpecial\">⚡<br>خاص</div>\n  </div>\n</div>\n\n<div id=\"gameOver\">\n  <h1 id=\"gameOverTitle\">انتهت اللعبة</h1>\n  <p id=\"gameOverMsg\">حاول مرة أخرى!</p>\n  <button id=\"restartBtn\" onclick=\"restartGame()\">🔄 إعادة اللعب</button>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nfunction resize() {\n  canvas.width = window.innerWidth;\n  canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// ===== GAME STATE =====\nlet keys = {};\nlet wins = 0, losses = 0, round = 1;\nlet gameActive = true;\nlet roundTimer = 0;\nlet particles = [];\nlet effects = [];\n\n// ===== PLAYER =====\nlet player = {\n  x: 0, y: 0, z: 0,\n  vx: 0, vy: 0, vz: 0,\n  hp: 100, maxHp: 100,\n  state: 'idle',\n  stateTimer: 0,\n  facing: 1,\n  isBlocking: false,\n  attackCooldown: 0,\n  specialCooldown: 0,\n  comboCount: 0,\n  comboTimer: 0,\n  hitFlash: 0,\n  color: '#00aaff',\n  shadowColor: '#0044aa',\n  width: 40, height: 70,\n  onGround: true,\n  invincible: 0,\n};\n\n// ===== ENEMY AI =====\nlet enemy = {\n  x: 0, y: 0, z: 0,\n  vx: 0, vy: 0, vz: 0,\n  hp: 100, maxHp: 100,\n  state: 'idle',\n  stateTimer: 0,\n  facing: -1,\n  isBlocking: false,\n  attackCooldown: 0,\n  aiTimer: 0,\n  aiAction: 'approach',\n  hitFlash: 0,\n  color: '#ff4400',\n  shadowColor: '#aa1100',\n  width: 40, height: 70,\n  onGround: true,\n  invincible: 0,\n};\n\n// ===== ARENA =====\nconst arena = {\n  floorY: 0,\n  width: 600,\n  depth: 300,\n};\n\nfunction initGame() {\n  player.x = -150; player.y = 0; player.z = 0;\n  player.vx = 0; player.vy = 0; player.vz = 0;\n  player.hp = 100; player.state = 'idle'; player.stateTimer = 0;\n  player.facing = 1; player.isBlocking = false;\n  player.attackCooldown = 0; player.specialCooldown = 0;\n  player.comboCount = 0; player.comboTimer = 0;\n  player.hitFlash = 0; player.onGround = true; player.invincible = 0;\n\n  enemy.x = 150; enemy.y = 0; enemy.z = 0;\n  enemy.vx = 0; enemy.vy = 0; enemy.vz = 0;\n  enemy.hp = 100; enemy.state = 'idle'; enemy.stateTimer = 0;\n  enemy.facing = -1; enemy.isBlocking = false;\n  enemy.attackCooldown = 0; enemy.aiTimer = 0; enemy.aiAction = 'approach';\n  enemy.hitFlash = 0; enemy.onGround = true; enemy.invincible = 0;\n\n  particles = []; effects = [];\n  gameActive = true;\n  showRoundText('الجولة ' + round);\n  setTimeout(() => showRoundText('FIGHT!'), 1200);\n}\n\nfunction showRoundText(text) {\n  const el = document.getElementById('roundText');\n  el.textContent = text;\n  el.style.opacity = '1';\n  setTimeout(() => { el.style.opacity = '0'; }, 900);\n}\n\n// ===== 3D PROJECTION =====\nfunction project(x, y, z) {\n  const cx = canvas.width / 2;\n  const cy = canvas.height * 0.55;\n  const fov = 400;\n  const camZ = -500;\n  const dz = z - camZ;\n  const scale = fov / dz;\n  return {\n    sx: cx + x * scale,\n    sy: cy - y * scale,\n    scale: scale\n  };\n}\n\n// ===== DRAW FIGHTER =====\nfunction drawFighter(f, isPlayer) {\n  const p = project(f.x, f.y, f.z);\n  const s = p.scale;\n  const w = f.width * s;\n  const h = f.height * s;\n  const sx = p.sx;\n  const sy = p.sy;\n\n  // Shadow\n  ctx.save();\n  ctx.globalAlpha = 0.3;\n  ctx.fillStyle = '#000';\n  ctx.beginPath();\n  ctx.ellipse(sx, sy + 2*s, w * 0.6, h * 0.08, 0, 0, Math.PI * 2);\n  ctx.fill();\n  ctx.restore();\n\n  // Flash effect\n  let bodyColor = f.color;\n  let darkColor = f.shadowColor;\n  if (f.hitFlash > 0) {\n    bodyColor = '#ffffff';\n    darkColor = '#cccccc';\n  }\n\n  // Body parts\n  const legH = h * 0.35;\n  const torsoH = h * 0.35;\n  const headR = w * 0.35;\n  const torsoY = sy - legH;\n  const headY = torsoY - torsoH - headR;\n\n  // Legs\n  ctx.save();\n  if (f.state === 'kick') {\n    // Kick animation\n    const kickAngle = f.facing * Math.sin(f.stateTimer * 0.3) * 0.8;\n    ctx.save();\n    ctx.translate(sx - w*0.15, sy - legH*0.5);\n    ctx.rotate(kickAngle);\n    ctx.fillStyle = darkColor;\n    ctx.fillRect(-w*0.15, -legH*0.5, w*0.3, legH*0.5);\n    ctx.restore();\n    ctx.fillStyle = darkColor;\n    ctx.fillRect(sx - w*0.05, sy - legH, w*0.3, legH);\n  } else if (f.state === 'jump' || !f.onGround) {\n    ctx.fillStyle = darkColor"}]