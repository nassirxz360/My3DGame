[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: Arial, sans-serif; touch-action: none; }\n  #gameCanvas { display: block; width: 100vw; height: 100vh; }\n  #ui {\n    position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10;\n  }\n  .health-bar-container {\n    display: flex; justify-content: space-between; padding: 15px 20px; align-items: flex-start;\n  }\n  .player-hud { display: flex; flex-direction: column; gap: 5px; }\n  .hud-name { color: #fff; font-size: 14px; font-weight: bold; text-shadow: 2px 2px 4px #000; }\n  .health-bar-bg {\n    width: 200px; height: 20px; background: #333; border-radius: 10px;\n    border: 2px solid #555; overflow: hidden;\n  }\n  .health-bar { height: 100%; border-radius: 8px; transition: width 0.3s; }\n  .p1-bar { background: linear-gradient(90deg, #ff4444, #ff8800); }\n  .p2-bar { background: linear-gradient(90deg, #4488ff, #44ffff); }\n  .energy-bar-bg {\n    width: 200px; height: 10px; background: #222; border-radius: 5px;\n    border: 1px solid #444; overflow: hidden;\n  }\n  .energy-bar { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #ffff00, #ffaa00); transition: width 0.2s; }\n  #centerUI {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);\n    text-align: center; z-index: 20; pointer-events: none;\n  }\n  #roundText {\n    color: #fff; font-size: 48px; font-weight: bold;\n    text-shadow: 0 0 20px #ff8800, 2px 2px 8px #000;\n    animation: pulse 0.5s ease-in-out;\n  }\n  @keyframes pulse {\n    0% { transform: scale(0.5); opacity: 0; }\n    100% { transform: scale(1); opacity: 1; }\n  }\n  #timer {\n    position: fixed; top: 15px; left: 50%; transform: translateX(-50%);\n    color: #fff; font-size: 36px; font-weight: bold;\n    text-shadow: 0 0 10px #ff4444; z-index: 10; pointer-events: none;\n  }\n  #roundInfo {\n    position: fixed; top: 60px; left: 50%; transform: translateX(-50%);\n    color: #ffaa00; font-size: 16px; font-weight: bold;\n    text-shadow: 2px 2px 4px #000; z-index: 10; pointer-events: none;\n  }\n  /* Mobile Controls */\n  #mobileControls {\n    position: fixed; bottom: 0; left: 0; width: 100%; height: 220px;\n    z-index: 15; pointer-events: none;\n  }\n  #leftControls {\n    position: absolute; left: 10px; bottom: 10px;\n    width: 180px; height: 180px; pointer-events: all;\n  }\n  #rightControls {\n    position: absolute; right: 10px; bottom: 10px;\n    width: 200px; height: 200px; pointer-events: all;\n  }\n  .dpad {\n    position: relative; width: 150px; height: 150px; margin: 15px auto;\n  }\n  .dpad-btn {\n    position: absolute; width: 45px; height: 45px;\n    background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.4);\n    border-radius: 8px; display: flex; align-items: center; justify-content: center;\n    color: #fff; font-size: 18px; cursor: pointer; user-select: none;\n    backdrop-filter: blur(5px); transition: background 0.1s;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .dpad-btn:active, .dpad-btn.pressed {\n    background: rgba(255,150,0,0.5); border-color: #ff8800;\n  }\n  .dpad-up { top: 0; left: 50%; transform: translateX(-50%); }\n  .dpad-down { bottom: 0; left: 50%; transform: translateX(-50%); }\n  .dpad-left { left: 0; top: 50%; transform: translateY(-50%); }\n  .dpad-right { right: 0; top: 50%; transform: translateY(-50%); }\n  .dpad-center {\n    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);\n    width: 35px; height: 35px; background: rgba(255,255,255,0.1);\n    border-radius: 50%; border: 1px solid rgba(255,255,255,0.2);\n  }\n  .action-buttons {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;\n    padding: 10px;\n  }\n  .action-btn {\n    width: 65px; height: 65px; border-radius: 50%;\n    border: 3px solid rgba(255,255,255,0.5);\n    display: flex; align-items: center; justify-content: center;\n    color: #fff; font-size: 11px; font-weight: bold; cursor: pointer;\n    user-select: none; text-align: center; line-height: 1.2;\n    -webkit-tap-highlight-color: transparent; transition: transform 0.1s;\n  }\n  .action-btn:active, .action-btn.pressed { transform: scale(0.9); }\n  .btn-punch { background: rgba(255,80,80,0.6); border-color: #ff4444; }\n  .btn-kick { background: rgba(255,150,0,0.6); border-color: #ff8800; }\n  .btn-block { background: rgba(80,80,255,0.6); border-color: #4444ff; }\n  .btn-special { background: rgba(150,0,255,0.6); border-color: #aa00ff; }\n  #jumpBtn {\n    position: absolute; left: 50%; bottom: 20px; transform: translateX(-50%);\n    width: 60px; height: 60px; border-radius: 50%;\n    background: rgba(0,200,100,0.6); border: 3px solid #00cc66;\n    color: #fff; font-size: 12px; font-weight: bold;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; pointer-events: all;\n    -webkit-tap-highlight-color: transparent;\n  }\n  #jumpBtn:active { transform: translateX(-50%) scale(0.9); }\n  #startScreen {\n    position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n    background: linear-gradient(135deg, #0a0a1a, #1a0a2e, #0a1a0a);\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    z-index: 100; color: #fff;\n  }\n  #startScreen h1 {\n    font-size: 52px; font-weight: 900; margin-bottom: 10px;\n    background: linear-gradient(90deg, #ff4444, #ff8800, #ffff00);\n    -webkit-background-clip: text; -webkit-text-fill-color: transparent;\n    text-shadow: none; animation: glow 2s infinite alternate;\n  }\n  @keyframes glow {\n    from { filter: drop-shadow(0 0 10px #ff4444); }\n    to { filter: drop-shadow(0 0 30px #ff8800); }\n  }\n  #startScreen p { color: #aaa; margin-bottom: 40px; font-size: 16px; }\n  .start-btn {\n    padding: 18px 60px; font-size: 22px; font-weight: bold;\n    background: linear-gradient(135deg, #ff4444, #ff8800);\n    color: #fff; border: none; border-radius: 50px; cursor: pointer;\n    box-shadow: 0 0 30px rgba(255,100,0,0.5); transition: transform 0.2s;\n    margin: 10px;\n  }\n  .start-btn:hover { transform: scale(1.05); }\n  #gameOverScreen {\n    position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n    background: rgba(0,0,0,0.85); display: none;\n    flex-direction: column; align-items: center; justify-content: center;\n    z-index: 100; color: #fff;\n  }\n  #gameOverScreen h2 { font-size: 48px; margin-bottom: 20px; color: #ff8800; }\n  #winnerText { font-size: 28px; margin-bottom: 30px; color: #ffff00; }\n  .score-display {\n    display: flex; gap: 40px; margin-bottom: 30px;\n  }\n  .score-item { text-align: center; }\n  .score-item .score-num { font-size: 48px; font-weight: bold; }\n  .score-item .score-label { font-size: 14px; color: #aaa; }\n  #p1score { color: #ff4444; }\n  #p2score { color: #4488ff; }\n  #comboDisplay {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);\n    color: #ffff00; font-size: 32px; font-weight: bold;\n    text-shadow: 0 0 20px #ff8800; z-index: 10; pointer-events: none;\n    opacity: 0; transition: opacity 0.3s;\n  }\n</style>\n</head>\n<body>\n\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div class=\"health-bar-container\">\n    <div class=\"player-hud\">\n      <div class=\"hud-name\">🔴 المقاتل 1</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar p1-bar\" id=\"p1health\" style=\"width:100%\"></div></div>\n      <div class=\"energy-bar-bg\"><div class=\"energy-bar\" id=\"p1energy\" style=\"width:0%\"></div></div>\n    </div>\n    <div class=\"player-hud\" style=\"align-items:flex-end\">\n      <div class=\"hud-name\">🔵 المقاتل 2 (AI)</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar p2-bar\" id=\"p2health\" style=\"width:100%\"></div></div>\n      <div class=\"energy-bar-bg\"><div class=\"energy-bar\" id=\"p2energy\" style=\"width:0%\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"timer\">60</div>\n<div id=\"roundInfo\">الجولة 1</div>\n<div id=\"centerUI\"><div id=\"roundText\"></div></div>\n<div id=\"comboDisplay\"></div>\n\n<div id=\"mobileControls\">\n  <div id=\"leftControls\">\n    <div class=\"dpad\">\n      <div class=\"dpad-btn dpad-up\" id=\"btnUp\">▲</div>\n      <div class=\"dpad-btn dpad-down\" id=\"btnDown\">▼</div>\n      <div class=\"dpad-btn dpad-left\" id=\"btnLeft\">◀</div>\n      <div class=\"dpad-btn dpad-right\" id=\"btnRight\">▶</div>\n      <div class=\"dpad-center\"></div>\n    </div>\n  </div>\n  <div id=\"jumpBtn\" id=\"btnJump\">⬆<br>قفز</div>\n  <div id=\"rightControls\">\n    <div class=\"action-buttons\">\n      <div class=\"action-btn btn-punch\" id=\"btnPunch\">👊<br>لكمة</div>\n      <div class=\"action-btn btn-kick\" id=\"btnKick\">🦵<br>ركلة</div>\n      <div class=\"action-btn btn-block\" id=\"btnBlock\">🛡<br>دفاع</div>\n      <div class=\"action-btn btn-special\" id=\"btnSpecial\">⚡<br>خاص</div>\n    </div>\n  </div>\n</div>\n\n<div id=\"startScreen\">\n  <h1>⚔️ القتال 3D</h1>\n  <p>لعبة قتال ثلاثية الأبعاد</p>\n  <button class=\"start-btn\" onclick=\"startGame()\">🎮 ابدأ اللعبة</button>\n</div>\n\n<div id=\"gameOverScreen\">\n  <h2>🏆 انتهت اللعبة!</h2>\n  <div id=\"winnerText\"></div>\n  <div class=\"score-display\">\n    <div class=\"score-item\"><div class=\"score-num\" id=\"p1score\" style=\"color:#ff4444\">0</div><div class=\"score-label\">المقاتل 1</div></div>\n    <div class=\"score-item\"><div style=\"font-size:32px;margin-top:8px\">VS</div></div>\n    <div class=\"score-item\"><div class=\"score-num\" id=\"p2score\" style=\"color:#4488ff\">0</div><div class=\"score-label\">المقاتل 2</div></div>\n  </div>\n  <button class=\"start-btn\" onclick=\"restartGame()\">🔄 العب مجددًا</button>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nfunction resize() {\n  canvas.width = window.innerWidth;\n  canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// Game State\\"}]