[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: Arial, sans-serif; touch-action: none; }\n  #gameCanvas { display: block; width: 100vw; height: 100vh; }\n  #ui {\n    position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10;\n  }\n  .health-bar-container {\n    display: flex; justify-content: space-between; align-items: flex-start;\n    padding: 10px 15px;\n  }\n  .fighter-info { width: 42%; }\n  .fighter-name {\n    color: #fff; font-size: 13px; font-weight: bold;\n    text-shadow: 1px 1px 3px #000; margin-bottom: 4px;\n  }\n  .health-bar-bg {\n    width: 100%; height: 18px; background: #333;\n    border: 2px solid #666; border-radius: 4px; overflow: hidden;\n  }\n  .health-bar {\n    height: 100%; background: linear-gradient(90deg, #ff2200, #ff6600);\n    transition: width 0.2s; border-radius: 2px;\n  }\n  #player2-info .health-bar {\n    background: linear-gradient(90deg, #0066ff, #00ccff);\n    margin-left: auto;\n  }\n  #player2-info .health-bar-bg { direction: rtl; }\n  .vs-text {\n    color: #ffcc00; font-size: 20px; font-weight: bold;\n    text-shadow: 0 0 10px #ff6600; padding-top: 5px;\n  }\n  #timer {\n    position: fixed; top: 10px; left: 50%; transform: translateX(-50%);\n    color: #ffcc00; font-size: 28px; font-weight: bold;\n    text-shadow: 0 0 10px #ff6600, 1px 1px 3px #000;\n    z-index: 11; pointer-events: none;\n  }\n  #message {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);\n    color: #ffcc00; font-size: 40px; font-weight: bold;\n    text-shadow: 0 0 20px #ff0000, 2px 2px 5px #000;\n    z-index: 20; pointer-events: none; display: none;\n    text-align: center; background: rgba(0,0,0,0.6);\n    padding: 20px 40px; border-radius: 15px;\n    border: 3px solid #ffcc00;\n  }\n  #controls-left {\n    position: fixed; bottom: 20px; left: 15px;\n    z-index: 10; display: grid;\n    grid-template-areas: '. up .' 'left . right' '. down .';\n    gap: 5px;\n  }\n  #controls-right {\n    position: fixed; bottom: 20px; right: 15px;\n    z-index: 10; display: flex; flex-direction: column; gap: 8px; align-items: flex-end;\n  }\n  .btn-row { display: flex; gap: 8px; }\n  .dpad-btn {\n    width: 55px; height: 55px; border-radius: 10px;\n    background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.4);\n    color: #fff; font-size: 20px; display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; -webkit-user-select: none;\n    backdrop-filter: blur(5px); transition: background 0.1s;\n    touch-action: none;\n  }\n  .dpad-btn:active, .dpad-btn.pressed {\n    background: rgba(255,255,255,0.4);\n  }\n  .dpad-btn[data-dir='up'] { grid-area: up; }\n  .dpad-btn[data-dir='left'] { grid-area: left; }\n  .dpad-btn[data-dir='right'] { grid-area: right; }\n  .dpad-btn[data-dir='down'] { grid-area: down; }\n  .action-btn {\n    width: 60px; height: 60px; border-radius: 50%;\n    border: 3px solid; color: #fff; font-size: 11px; font-weight: bold;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; -webkit-user-select: none;\n    backdrop-filter: blur(5px); transition: all 0.1s;\n    touch-action: none; text-align: center; line-height: 1.2;\n  }\n  .action-btn:active, .action-btn.pressed {\n    transform: scale(0.9); filter: brightness(1.5);\n  }\n  .btn-punch {\n    background: rgba(255,80,0,0.4); border-color: #ff5000;\n  }\n  .btn-kick {\n    background: rgba(255,200,0,0.4); border-color: #ffcc00;\n  }\n  .btn-block {\n    background: rgba(0,150,255,0.4); border-color: #0096ff;\n  }\n  .btn-special {\n    background: rgba(180,0,255,0.4); border-color: #b400ff;\n  }\n  #restart-btn {\n    position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);\n    z-index: 20; display: none;\n    background: linear-gradient(135deg, #ff6600, #ff2200);\n    color: #fff; border: none; padding: 15px 40px;\n    font-size: 18px; font-weight: bold; border-radius: 30px;\n    cursor: pointer; box-shadow: 0 0 20px rgba(255,100,0,0.7);\n  }\n  #combo-display {\n    position: fixed; top: 50%; right: 20px; transform: translateY(-50%);\n    color: #ffcc00; font-size: 22px; font-weight: bold;\n    text-shadow: 0 0 10px #ff6600; z-index: 11;\n    pointer-events: none; opacity: 0; transition: opacity 0.3s;\n  }\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div class=\"health-bar-container\">\n    <div class=\"fighter-info\" id=\"player1-info\">\n      <div class=\"fighter-name\">🥊 المقاتل 1</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar\" id=\"hp1-bar\" style=\"width:100%\"></div></div>\n    </div>\n    <div class=\"vs-text\">VS</div>\n    <div class=\"fighter-info\" id=\"player2-info\">\n      <div class=\"fighter-name\" style=\"text-align:left\">المقاتل 2 🤖</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar\" id=\"hp2-bar\" style=\"width:100%\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"timer\">60</div>\n<div id=\"message\"></div>\n<div id=\"combo-display\"></div>\n\n<div id=\"controls-left\">\n  <div class=\"dpad-btn\" data-dir=\"up\" id=\"btn-up\">▲</div>\n  <div class=\"dpad-btn\" data-dir=\"left\" id=\"btn-left\">◀</div>\n  <div class=\"dpad-btn\" data-dir=\"right\" id=\"btn-right\">▶</div>\n  <div class=\"dpad-btn\" data-dir=\"down\" id=\"btn-down\">▼</div>\n</div>\n\n<div id=\"controls-right\">\n  <div class=\"btn-row\">\n    <div class=\"action-btn btn-special\" id=\"btn-special\">⚡<br>خاص</div>\n    <div class=\"action-btn btn-punch\" id=\"btn-punch\">👊<br>لكمة</div>\n  </div>\n  <div class=\"btn-row\">\n    <div class=\"action-btn btn-block\" id=\"btn-block\">🛡️<br>دفاع</div>\n    <div class=\"action-btn btn-kick\" id=\"btn-kick\">🦵<br>ركلة</div>\n  </div>\n</div>\n\n<button id=\"restart-btn\" onclick=\"restartGame()\">🔄 إعادة اللعب</button>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nfunction resize() {\n  canvas.width = window.innerWidth;\n  canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// ===== GAME STATE =====\nlet gameOver = false;\nlet gameTime = 60;\nlet timerInterval;\nlet comboCount = 0;\nlet comboTimer = null;\nlet animFrame;\n\n// ===== PERSPECTIVE =====\nconst CAM = { fov: 600, z: 800 };\n\nfunction project(x, y, z) {\n  const scale = CAM.fov / (CAM.fov + z + CAM.z);\n  return {\n    x: canvas.width / 2 + x * scale,\n    y: canvas.height * 0.75 + y * scale,\n    scale\n  };\n}\n\n// ===== ARENA =====\nconst arena = {\n  w: 600, d: 300, h: 0,\n  draw() {\n    // Floor grid\n    const corners = [\n      project(-this.w, 0, -this.d),\n      project(this.w, 0, -this.d),\n      project(this.w, 0, this.d),\n      project(-this.w, 0, this.d)\n    ];\n    // Floor\n    ctx.beginPath();\n    ctx.moveTo(corners[0].x, corners[0].y);\n    ctx.lineTo(corners[1].x, corners[1].y);\n    ctx.lineTo(corners[2].x, corners[2].y);\n    ctx.lineTo(corners[3].x, corners[3].y);\n    ctx.closePath();\n    const grad = ctx.createLinearGradient(corners[0].x, corners[0].y, corners[2].x, corners[2].y);\n    grad.addColorStop(0, '#1a0a2e');\n    grad.addColorStop(0.5, '#2d1b4e');\n    grad.addColorStop(1, '#1a0a2e');\n    ctx.fillStyle = grad;\n    ctx.fill();\n    ctx.strokeStyle = '#6600cc';\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    // Grid lines\n    ctx.strokeStyle = 'rgba(100,0,200,0.3)';\n    ctx.lineWidth = 1;\n    for (let i = -5; i <= 5; i++) {\n      const x = i * (this.w / 5);\n      const p1 = project(x, 0, -this.d);\n      const p2 = project(x, 0, this.d);\n      ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();\n    }\n    for (let i = -3; i <= 3; i++) {\n      const z = i * (this.d / 3);\n      const p1 = project(-this.w, 0, z);\n      const p2 = project(this.w, 0, z);\n      ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();\n    }\n    // Back wall\n    const wallCorners = [\n      project(-this.w, 0, -this.d),\n      project(this.w, 0, -this.d),\n      project(this.w, -300, -this.d),\n      project(-this.w, -300, -this.d)\n    ];\n    ctx.beginPath();\n    ctx.moveTo(wallCorners[0].x, wallCorners[0].y);\n    ctx.lineTo(wallCorners[1].x, wallCorners[1].y);\n    ctx.lineTo(wallCorners[2].x, wallCorners[2].y);\n    ctx.lineTo(wallCorners[3].x, wallCorners[3].y);\n    ctx.closePath();\n    const wGrad = ctx.createLinearGradient(0, wallCorners[3].y, 0, wallCorners[0].y);\n    wGrad.addColorStop(0, '#0d0020');\n    wGrad.addColorStop(1, '#1a0040');\n    ctx.fillStyle = wGrad;\n    ctx.fill();\n    ctx.strokeStyle = '#6600cc';\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    // Neon lines on wall\n    for (let i = 0; i < 5; i++) {\n      const wx = -this.w + i * (this.w * 2 / 4);\n      const p1 = project(wx, 0, -this.d);\n      const p2 = project(wx, -300, -this.d);\n      ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y);\n      ctx.strokeStyle = `rgba(${i%2?0:255},0,${i%2?255:100},0.4)`;\n      ctx.lineWidth = 1; ctx.stroke();\n    }\n  }\n};\n\n// ===== PARTICLES =====\nlet particles = [];\nfunction spawnParticles(x, y, z, color, count) {\n  for (let i = 0; i < count; i++) {\n    particles.push({\n      x, y, z,\n      vx: (Math.random() - 0.5) * 8,\n      vy: -(Math.random() * 6 + 2),\n      vz: (Math.random() - 0.5) * 4,\n      life: 1, decay: Math.random() * 0.05 + 0.03,\n      size: Math.random"}]