[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: Arial, sans-serif; touch-action: none; }\n  canvas { display: block; }\n  #ui {\n    position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10;\n  }\n  #health-bars {\n    display: flex; justify-content: space-between; padding: 10px 20px;\n    align-items: flex-start;\n  }\n  .fighter-info { width: 45%; }\n  .fighter-name { color: #fff; font-size: 14px; font-weight: bold; margin-bottom: 4px; text-shadow: 2px 2px 4px #000; }\n  .health-bar-bg {\n    width: 100%; height: 20px; background: #333;\n    border: 2px solid #666; border-radius: 3px; overflow: hidden;\n  }\n  .health-bar { height: 100%; transition: width 0.1s; border-radius: 2px; }\n  #p1-health { background: linear-gradient(90deg, #ff4444, #ff8800); }\n  #p2-health { background: linear-gradient(90deg, #4488ff, #44ffff); float: right; }\n  .fighter2-info { text-align: left; }\n  #timer-box {\n    position: fixed; top: 10px; left: 50%; transform: translateX(-50%);\n    background: rgba(0,0,0,0.7); border: 2px solid #ff8800;\n    color: #ff8800; font-size: 28px; font-weight: bold;\n    padding: 5px 20px; border-radius: 8px; z-index: 11;\n    text-shadow: 0 0 10px #ff8800;\n  }\n  #message {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);\n    color: #fff; font-size: 48px; font-weight: bold;\n    text-shadow: 3px 3px 0 #000, 0 0 20px #ff8800;\n    z-index: 20; display: none; text-align: center;\n    animation: pulse 0.5s infinite alternate;\n  }\n  @keyframes pulse { from { transform: translate(-50%,-50%) scale(1); } to { transform: translate(-50%,-50%) scale(1.1); } }\n  #controls-left {\n    position: fixed; bottom: 20px; left: 20px;\n    display: grid; grid-template-columns: 60px 60px 60px;\n    grid-template-rows: 60px 60px; gap: 5px; z-index: 15;\n  }\n  #controls-right {\n    position: fixed; bottom: 20px; right: 20px;\n    display: grid; grid-template-columns: 65px 65px;\n    grid-template-rows: 65px 65px; gap: 8px; z-index: 15;\n  }\n  .dpad-btn {\n    background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.4);\n    border-radius: 10px; color: #fff; font-size: 22px;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; -webkit-user-select: none;\n    transition: background 0.1s; backdrop-filter: blur(4px);\n  }\n  .dpad-btn:active, .dpad-btn.pressed {\n    background: rgba(255,255,255,0.4);\n    border-color: #ff8800;\n  }\n  .action-btn {\n    border-radius: 50%; color: #fff; font-size: 13px; font-weight: bold;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; -webkit-user-select: none;\n    border: 3px solid rgba(255,255,255,0.5);\n    transition: all 0.1s; text-align: center; line-height: 1.2;\n  }\n  .action-btn:active, .action-btn.pressed { transform: scale(0.9); filter: brightness(1.5); }\n  #btn-punch { background: radial-gradient(circle, #ff4444, #aa0000); }\n  #btn-kick  { background: radial-gradient(circle, #ff8800, #aa5500); }\n  #btn-block { background: radial-gradient(circle, #4488ff, #0044aa); }\n  #btn-special { background: radial-gradient(circle, #aa44ff, #660099); }\n  #btn-up { grid-column: 2; grid-row: 1; }\n  #btn-left { grid-column: 1; grid-row: 2; }\n  #btn-down { grid-column: 2; grid-row: 2; }\n  #btn-right { grid-column: 3; grid-row: 2; }\n  #restart-btn {\n    position: fixed; top: 60%; left: 50%; transform: translateX(-50%);\n    background: linear-gradient(135deg, #ff8800, #ff4444);\n    color: #fff; font-size: 20px; font-weight: bold;\n    padding: 15px 40px; border: none; border-radius: 10px;\n    cursor: pointer; z-index: 25; display: none;\n    box-shadow: 0 4px 15px rgba(255,136,0,0.5);\n  }\n  #combo-text {\n    position: fixed; top: 120px; left: 50%; transform: translateX(-50%);\n    color: #ffff00; font-size: 32px; font-weight: bold;\n    text-shadow: 2px 2px 0 #000; z-index: 12;\n    opacity: 0; transition: opacity 0.3s;\n  }\n  #special-bar-p1, #special-bar-p2 {\n    height: 8px; margin-top: 4px; border-radius: 3px;\n    border: 1px solid #666; overflow: hidden;\n  }\n  #special-bar-p1 { background: #222; }\n  #special-bar-p2 { background: #222; }\n  .special-fill { height: 100%; background: linear-gradient(90deg, #aa44ff, #ff44ff); transition: width 0.2s; }\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div id=\"health-bars\">\n    <div class=\"fighter-info\">\n      <div class=\"fighter-name\">🔴 المقاتل 1</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar\" id=\"p1-health\" style=\"width:100%\"></div></div>\n      <div id=\"special-bar-p1\"><div class=\"special-fill\" id=\"p1-special\" style=\"width:0%\"></div></div>\n    </div>\n    <div class=\"fighter-info fighter2-info\">\n      <div class=\"fighter-name\" style=\"text-align:right\">المقاتل 2 🔵</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar\" id=\"p2-health\" style=\"width:100%;float:right\"></div></div>\n      <div id=\"special-bar-p2\"><div class=\"special-fill\" id=\"p2-special\" style=\"width:0%;float:right\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"timer-box\">60</div>\n<div id=\"message\"></div>\n<div id=\"combo-text\"></div>\n<button id=\"restart-btn\" onclick=\"restartGame()\">🔄 إعادة اللعبة</button>\n\n<div id=\"controls-left\">\n  <div class=\"dpad-btn\" id=\"btn-up\">▲</div>\n  <div class=\"dpad-btn\" id=\"btn-left\">◀</div>\n  <div class=\"dpad-btn\" id=\"btn-down\">▼</div>\n  <div class=\"dpad-btn\" id=\"btn-right\">▶</div>\n</div>\n\n<div id=\"controls-right\">\n  <div class=\"action-btn\" id=\"btn-punch\">👊<br>لكمة</div>\n  <div class=\"action-btn\" id=\"btn-kick\">🦵<br>ركلة</div>\n  <div class=\"action-btn\" id=\"btn-block\">🛡️<br>دفاع</div>\n  <div class=\"action-btn\" id=\"btn-special\">⚡<br>خاص</div>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nfunction resize() {\n  canvas.width = window.innerWidth;\n  canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// ===== GAME STATE =====\nlet gameOver = false;\nlet gameTimer = 60;\nlet timerInterval;\nlet comboTimeout;\n\nconst keys = {};\nconst mobileInput = {\n  up: false, down: false, left: false, right: false,\n  punch: false, kick: false, block: false, special: false\n};\n\n// ===== PARTICLES =====\nlet particles = [];\nfunction spawnParticles(x, y, color, count) {\n  for (let i = 0; i < count; i++) {\n    particles.push({\n      x, y,\n      vx: (Math.random() - 0.5) * 8,\n      vy: (Math.random() - 3) * 6,\n      life: 1, color,\n      size: Math.random() * 8 + 3\n    });\n  }\n}\nfunction updateParticles() {\n  particles = particles.filter(p => p.life > 0);\n  particles.forEach(p => {\n    p.x += p.vx; p.y += p.vy;\n    p.vy += 0.3; p.life -= 0.04;\n  });\n}\nfunction drawParticles() {\n  particles.forEach(p => {\n    ctx.save();\n    ctx.globalAlpha = p.life;\n    ctx.fillStyle = p.color;\n    ctx.beginPath();\n    ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);\n    ctx.fill();\n    ctx.restore();\n  });\n}\n\n// ===== FIGHTER CLASS =====\nclass Fighter {\n  constructor(x, color, name, isPlayer2) {\n    this.x = x;\n    this.y = 0;\n    this.vy = 0;\n    this.width = 50;\n    this.height = 90;\n    this.color = color;\n    this.name = name;\n    this.isPlayer2 = isPlayer2;\n    this.health = 100;\n    this.special = 0;\n    this.speed = 4;\n    this.facing = isPlayer2 ? -1 : 1;\n    this.state = 'idle';\n    this.stateTimer = 0;\n    this.attackBox = null;\n    this.isBlocking = false;\n    this.combo = 0;\n    this.comboTimer = 0;\n    this.hitFlash = 0;\n    this.animFrame = 0;\n    this.animTimer = 0;\n    this.groundY = 0;\n    this.isJumping = false;\n    this.shadow = true;\n    this.knockback = 0;\n    this.invincible = 0;\n  }\n\n  get cx() { return this.x + this.width / 2; }\n  get cy() { return this.y + this.height / 2; }\n  get bottom() { return this.y + this.height; }\n\n  jump() {\n    if (!this.isJumping && this.state !== 'attack' && this.state !== 'hurt') {\n      this.vy = -18;\n      this.isJumping = true;\n      this.state = 'jump';\n    }\n  }\n\n  attack(type) {\n    if (this.state === 'attack' || this.state === 'hurt') return;\n    this.state = 'attack';\n    this.stateTimer = type === 'punch' ? 20 : type === 'kick' ? 28 : 35;\n    this.attackType = type;\n    let reach = type === 'punch' ? 70 : type === 'kick' ? 90 : 120;\n    let dmg = type === 'punch' ? 8 : type === 'kick' ? 12 : 25;\n    let kbForce = type === 'punch' ? 5 : type === 'kick' ? 8 : 15;\n    this.attackBox = {\n      x: this.facing > 0 ? this.x + this.width : this.x - reach,\n      y: this.y + 20,\n      w: reach, h: 50,\n      damage: dmg,\n      knockback: kbForce * this.facing,\n      type\n    };\n    setTimeout(() => { this.attackBox = null; }, 150);\n  }\n\n  block(on) {\n    if (this.state !== 'attack' && this.state !== 'hurt') {\n      this.isBlocking = on;\n      if (on) this.state = 'block';\n      else if (this.state === 'block') this.state = 'idle';\n    }\n  }\n\n  takeDamage(dmg, knockback) {\n    if (this.invincible > 0) return;\n    if (this.isBlocking) {\n      dmg = Math.floor(dmg * 0.15);\n      knockback *= 0.3;\n      spawnParticles(this.cx, this.cy, '#88aaff', 5);\n    } else {\n      spawnParticles(this.cx, this.cy - 20, '#ff4444', 10);\n      this.state = 'hurt';\n      this.stateTimer = 15;\n      this.invincible = 20;\n    }\n    this.health = Math.max(0, this.health - dmg);\n    this.knockback = knockback;\n    this.hitFlash = 8;\n    this.special = Math.min(100, this.special + dmg * 0.5);\n  }\n\n  useSpecial(target) {\n    if (this.special < 100 || this.state === 'attack' ||"}]