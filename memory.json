[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: Arial, sans-serif; touch-action: none; }\n  #gameCanvas { display: block; width: 100vw; height: 100vh; }\n  #ui {\n    position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10;\n  }\n  .health-bar-container {\n    display: flex; justify-content: space-between; align-items: center;\n    padding: 10px 15px; background: rgba(0,0,0,0.6);\n  }\n  .fighter-info { display: flex; flex-direction: column; gap: 4px; }\n  .fighter-name { color: #fff; font-size: 14px; font-weight: bold; text-shadow: 0 0 5px #f00; }\n  .health-bar-bg {\n    width: 160px; height: 18px; background: #333;\n    border: 2px solid #666; border-radius: 4px; overflow: hidden;\n  }\n  .health-bar { height: 100%; transition: width 0.2s; border-radius: 2px; }\n  #p1health { background: linear-gradient(90deg, #f00, #ff6600); }\n  #p2health { background: linear-gradient(90deg, #ff6600, #f00); }\n  .fighter-info.right { align-items: flex-end; }\n  .fighter-info.right .health-bar-bg { direction: rtl; }\n  #timer {\n    color: #fff; font-size: 28px; font-weight: bold;\n    text-align: center; text-shadow: 0 0 10px #ff0;\n    background: rgba(0,0,0,0.7); padding: 2px 20px;\n    border-radius: 8px; display: inline-block;\n  }\n  #timer-wrap { text-align: center; margin-top: 5px; }\n  #round-display {\n    color: #ff0; font-size: 13px; text-align: center;\n    text-shadow: 0 0 5px #ff0;\n  }\n  #message {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);\n    color: #fff; font-size: 48px; font-weight: bold;\n    text-shadow: 0 0 20px #f00, 0 0 40px #f00;\n    pointer-events: none; z-index: 20;\n    opacity: 0; transition: opacity 0.3s;\n    text-align: center;\n  }\n  /* Mobile Controls */\n  #controls {\n    position: fixed; bottom: 0; left: 0; width: 100%;\n    display: flex; justify-content: space-between; align-items: flex-end;\n    padding: 10px; z-index: 15; pointer-events: none;\n  }\n  .dpad {\n    display: grid; grid-template-columns: repeat(3, 55px);\n    grid-template-rows: repeat(3, 55px); gap: 4px;\n    pointer-events: all;\n  }\n  .dpad-btn {\n    background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3);\n    border-radius: 10px; color: #fff; font-size: 22px;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; -webkit-user-select: none;\n    transition: background 0.1s; touch-action: none;\n  }\n  .dpad-btn:active, .dpad-btn.pressed {\n    background: rgba(255,100,0,0.5); border-color: #ff6600;\n  }\n  .dpad-empty { background: transparent; border: none; }\n  .action-btns {\n    display: grid; grid-template-columns: repeat(2, 65px);\n    grid-template-rows: repeat(2, 65px); gap: 8px;\n    pointer-events: all;\n  }\n  .action-btn {\n    border-radius: 50%; border: 3px solid;\n    color: #fff; font-size: 13px; font-weight: bold;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer; user-select: none; -webkit-user-select: none;\n    transition: all 0.1s; touch-action: none; text-align: center;\n    line-height: 1.2;\n  }\n  .action-btn:active, .action-btn.pressed {\n    transform: scale(0.9); filter: brightness(1.5);\n  }\n  .btn-punch { background: rgba(255,50,50,0.3); border-color: #ff3232; }\n  .btn-kick  { background: rgba(50,150,255,0.3); border-color: #3296ff; }\n  .btn-block { background: rgba(50,255,50,0.3);  border-color: #32ff32; }\n  .btn-special { background: rgba(255,200,0,0.3); border-color: #ffc800; }\n  #start-screen {\n    position: fixed; inset: 0; background: rgba(0,0,0,0.85);\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    z-index: 30; color: #fff;\n  }\n  #start-screen h1 {\n    font-size: 42px; color: #ff3300;\n    text-shadow: 0 0 20px #ff3300, 0 0 40px #ff0000;\n    margin-bottom: 10px;\n  }\n  #start-screen p { color: #aaa; margin-bottom: 30px; font-size: 16px; }\n  .start-btn {\n    background: linear-gradient(135deg, #ff3300, #ff6600);\n    border: none; color: #fff; padding: 15px 50px;\n    font-size: 22px; border-radius: 30px; cursor: pointer;\n    box-shadow: 0 0 20px #ff3300; margin: 8px;\n    font-weight: bold; transition: transform 0.1s;\n  }\n  .start-btn:active { transform: scale(0.95); }\n  #game-over-screen {\n    position: fixed; inset: 0; background: rgba(0,0,0,0.88);\n    display: none; flex-direction: column; align-items: center; justify-content: center;\n    z-index: 30; color: #fff;\n  }\n  #game-over-screen h2 { font-size: 38px; color: #ff0; text-shadow: 0 0 15px #ff0; margin-bottom: 10px; }\n  #winner-text { font-size: 26px; color: #fff; margin-bottom: 30px; }\n  #score-display { font-size: 18px; color: #aaa; margin-bottom: 20px; }\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div class=\"health-bar-container\">\n    <div class=\"fighter-info\">\n      <div class=\"fighter-name\">🔥 المقاتل 1</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar\" id=\"p1health\" style=\"width:100%\"></div></div>\n    </div>\n    <div style=\"text-align:center\">\n      <div id=\"timer-wrap\"><span id=\"timer\">60</span></div>\n      <div id=\"round-display\">الجولة 1</div>\n    </div>\n    <div class=\"fighter-info right\">\n      <div class=\"fighter-name\">⚡ المقاتل 2</div>\n      <div class=\"health-bar-bg\"><div class=\"health-bar\" id=\"p2health\" style=\"width:100%\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"message\"></div>\n\n<div id=\"controls\">\n  <div class=\"dpad\">\n    <div class=\"dpad-empty\"></div>\n    <div class=\"dpad-btn\" id=\"btn-up\">▲</div>\n    <div class=\"dpad-empty\"></div>\n    <div class=\"dpad-btn\" id=\"btn-left\">◀</div>\n    <div class=\"dpad-empty dpad-center\"></div>\n    <div class=\"dpad-btn\" id=\"btn-right\">▶</div>\n    <div class=\"dpad-empty\"></div>\n    <div class=\"dpad-btn\" id=\"btn-down\">▼</div>\n    <div class=\"dpad-empty\"></div>\n  </div>\n  <div class=\"action-btns\">\n    <div class=\"action-btn btn-punch\" id=\"btn-punch\">لكمة</div>\n    <div class=\"action-btn btn-kick\"  id=\"btn-kick\">ركلة</div>\n    <div class=\"action-btn btn-block\" id=\"btn-block\">دفاع</div>\n    <div class=\"action-btn btn-special\" id=\"btn-special\">خاص ⚡</div>\n  </div>\n</div>\n\n<div id=\"start-screen\">\n  <h1>⚔️ القتال 3D ⚔️</h1>\n  <p>لعبة قتال ثلاثية الأبعاد</p>\n  <button class=\"start-btn\" onclick=\"startGame()\">🎮 ابدأ اللعبة</button>\n</div>\n\n<div id=\"game-over-screen\">\n  <h2>🏆 انتهت اللعبة!</h2>\n  <div id=\"winner-text\"></div>\n  <div id=\"score-display\"></div>\n  <button class=\"start-btn\" onclick=\"restartGame()\">🔄 العب مجدداً</button>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nfunction resize() {\n  W = canvas.width  = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// ===== GAME STATE =====\nlet gameRunning = false;\nlet gameTime = 60;\nlet timerInterval = null;\nlet round = 1;\nlet p1Wins = 0, p2Wins = 0;\n\n// ===== KEYS =====\nconst keys = {};\nwindow.addEventListener('keydown', e => { keys[e.code] = true; });\nwindow.addEventListener('keyup',   e => { keys[e.code] = false; });\n\n// ===== MOBILE BUTTONS =====\nconst mobileState = {\n  up: false, down: false, left: false, right: false,\n  punch: false, kick: false, block: false, special: false\n};\n\nfunction bindBtn(id, key) {\n  const el = document.getElementById(id);\n  if (!el) return;\n  el.addEventListener('touchstart', e => { e.preventDefault(); mobileState[key] = true; el.classList.add('pressed'); }, { passive: false });\n  el.addEventListener('touchend',   e => { e.preventDefault(); mobileState[key] = false; el.classList.remove('pressed'); }, { passive: false });\n  el.addEventListener('mousedown',  e => { mobileState[key] = true;  el.classList.add('pressed'); });\n  el.addEventListener('mouseup',    e => { mobileState[key] = false; el.classList.remove('pressed'); });\n}\nbindBtn('btn-up',    'up');\nbindBtn('btn-down',  'down');\nbindBtn('btn-left',  'left');\nbindBtn('btn-right', 'right');\nbindBtn('btn-punch', 'punch');\nbindBtn('btn-kick',  'kick');\nbindBtn('btn-block', 'block');\nbindBtn('btn-special','special');\n\n// ===== 3D PERSPECTIVE =====\nconst CAM = { fov: 600, z: 800 };\nfunction project(x, y, z) {\n  const scale = CAM.fov / (CAM.fov + z + CAM.z);\n  return {\n    sx: W/2 + x * scale,\n    sy: H * 0.72 + y * scale,\n    scale\n  };\n}\n\n// ===== ARENA =====\nconst FLOOR_Y = 0;\nconst FLOOR_Z = 0;\n\nfunction drawArena() {\n  // Sky gradient\n  const sky = ctx.createLinearGradient(0, 0, 0, H * 0.65);\n  sky.addColorStop(0, '#0a0015');\n  sky.addColorStop(0.5, '#1a0030');\n  sky.addColorStop(1, '#2d0050');\n  ctx.fillStyle = sky;\n  ctx.fillRect(0, 0, W, H);\n\n  // Stars\n  ctx.fillStyle = 'rgba(255,255,255,0.6)';\n  for (let i = 0; i < 80; i++) {\n    const sx = (i * 137.5) % W;\n    const sy = (i * 97.3) % (H * 0.55);\n    ctx.fillRect(sx, sy, 1.5, 1.5);\n  }\n\n  // Floor grid\n  const floorTop = H * 0.55;\n  const floorBot = H;\n  const floorGrad = ctx.createLinearGradient(0, floorTop, 0, floorBot);\n  floorGrad.addColorStop(0, '#1a0030');\n  floorGrad.addColorStop(1, '#0d0020');\n  ctx.fillStyle = floorGrad;\n  ctx.fillRect(0, floorTop, W, floorBot - floorTop);\n\n  // Grid lines\n  ctx.strokeStyle = 'rgba(180,0,255,0.25)';\n  ctx.lineWidth = 1;\n  const vp = { x: W/2, y: floorTop };\n  for (let i = -10; i <= 10; i++) {\n    const bx = W/2 + i * (W / 12);\n    ctx.beginPath();\n    ctx.moveTo(vp.x + (bx - vp.x) * 0.02, floorTop);\n    ctx.lineTo(bx, floorBot);\n    ctx.stroke();\n  "}]