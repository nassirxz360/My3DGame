[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; overflow: hidden; font-family: Arial, sans-serif; touch-action: none; }\n#gameCanvas { display: block; width: 100vw; height: 100vh; }\n#ui { position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10; }\n#healthBars { display: flex; justify-content: space-between; padding: 15px; }\n.healthContainer { width: 40%; }\n.playerName { color: #fff; font-size: 14px; font-weight: bold; text-shadow: 2px 2px 4px #000; margin-bottom: 5px; }\n.healthBar { height: 20px; background: #333; border-radius: 10px; border: 2px solid #fff; overflow: hidden; }\n.healthFill { height: 100%; border-radius: 8px; transition: width 0.2s; }\n#p1Health .healthFill { background: linear-gradient(90deg, #ff4444, #ff8800); }\n#p2Health .healthFill { background: linear-gradient(90deg, #4444ff, #00aaff); }\n#p2Health { direction: ltr; }\n#roundInfo { text-align: center; color: #fff; font-size: 24px; font-weight: bold; text-shadow: 2px 2px 8px #000; padding: 10px; }\n#message { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #ffff00; font-size: 48px; font-weight: bold; text-shadow: 4px 4px 8px #000; z-index: 20; display: none; text-align: center; }\n#mobileControls { position: fixed; bottom: 0; left: 0; width: 100%; height: 220px; z-index: 15; pointer-events: none; }\n#leftControls { position: absolute; left: 10px; bottom: 10px; width: 180px; height: 180px; pointer-events: all; }\n#rightControls { position: absolute; right: 10px; bottom: 10px; width: 200px; height: 180px; pointer-events: all; }\n.dpad { position: relative; width: 150px; height: 150px; margin: 0 auto; }\n.dpad-btn { position: absolute; width: 50px; height: 50px; background: rgba(255,255,255,0.2); border: 2px solid rgba(255,255,255,0.5); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff; cursor: pointer; pointer-events: all; user-select: none; -webkit-user-select: none; transition: background 0.1s; }\n.dpad-btn:active, .dpad-btn.pressed { background: rgba(255,255,255,0.5); }\n#dpad-up { top: 0; left: 50px; }\n#dpad-down { bottom: 0; left: 50px; }\n#dpad-left { top: 50px; left: 0; }\n#dpad-right { top: 50px; right: 0; }\n.action-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 10px; }\n.action-btn { width: 80px; height: 80px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; color: #fff; cursor: pointer; pointer-events: all; user-select: none; -webkit-user-select: none; text-align: center; transition: transform 0.1s, opacity 0.1s; }\n.action-btn:active { transform: scale(0.9); opacity: 0.7; }\n#btn-punch { background: rgba(255, 100, 0, 0.6); }\n#btn-kick { background: rgba(255, 0, 100, 0.6); }\n#btn-block { background: rgba(0, 150, 255, 0.6); }\n#btn-special { background: rgba(150, 0, 255, 0.6); }\n#startScreen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 30; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; }\n#startScreen h1 { font-size: 48px; color: #ff8800; text-shadow: 4px 4px 8px #000; margin-bottom: 20px; }\n#startScreen p { font-size: 18px; margin-bottom: 30px; color: #aaa; }\n#startBtn { padding: 15px 50px; font-size: 24px; background: linear-gradient(135deg, #ff4400, #ff8800); color: #fff; border: none; border-radius: 30px; cursor: pointer; font-weight: bold; box-shadow: 0 4px 20px rgba(255,100,0,0.5); }\n#startBtn:hover { transform: scale(1.05); }\n#winScreen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 30; display: none; flex-direction: column; align-items: center; justify-content: center; color: #fff; }\n#winScreen h2 { font-size: 52px; color: #ffff00; text-shadow: 4px 4px 8px #000; margin-bottom: 20px; }\n#restartBtn { padding: 15px 50px; font-size: 22px; background: linear-gradient(135deg, #0044ff, #00aaff); color: #fff; border: none; border-radius: 30px; cursor: pointer; font-weight: bold; margin-top: 20px; }\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div id=\"healthBars\">\n    <div class=\"healthContainer\">\n      <div class=\"playerName\">🔴 المقاتل 1</div>\n      <div class=\"healthBar\" id=\"p1Health\"><div class=\"healthFill\" id=\"p1Fill\" style=\"width:100%\"></div></div>\n    </div>\n    <div id=\"roundInfo\">الجولة 1</div>\n    <div class=\"healthContainer\" style=\"text-align:right\">\n      <div class=\"playerName\" style=\"text-align:right\">المقاتل 2 🔵</div>\n      <div class=\"healthBar\" id=\"p2Health\"><div class=\"healthFill\" id=\"p2Fill\" style=\"width:100%\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"message\"></div>\n\n<div id=\"mobileControls\">\n  <div id=\"leftControls\">\n    <div class=\"dpad\">\n      <div class=\"dpad-btn\" id=\"dpad-up\" data-action=\"up\">▲</div>\n      <div class=\"dpad-btn\" id=\"dpad-left\" data-action=\"left\">◀</div>\n      <div class=\"dpad-btn\" id=\"dpad-right\" data-action=\"right\">▶</div>\n      <div class=\"dpad-btn\" id=\"dpad-down\" data-action=\"down\">▼</div>\n    </div>\n  </div>\n  <div id=\"rightControls\">\n    <div class=\"action-btns\">\n      <div class=\"action-btn\" id=\"btn-punch\" data-action=\"punch\">👊<br>لكمة</div>\n      <div class=\"action-btn\" id=\"btn-kick\" data-action=\"kick\">🦵<br>ركلة</div>\n      <div class=\"action-btn\" id=\"btn-block\" data-action=\"block\">🛡️<br>دفاع</div>\n      <div class=\"action-btn\" id=\"btn-special\" data-action=\"special\">⚡<br>خاص</div>\n    </div>\n  </div>\n</div>\n\n<div id=\"startScreen\">\n  <h1>⚔️ القتال 3D ⚔️</h1>\n  <p>العب ضد الذكاء الاصطناعي</p>\n  <p style=\"font-size:14px; color:#888\">لكمة: Z | ركلة: X | دفاع: C | خاص: V<br>تحرك: WASD أو الأسهم</p>\n  <button id=\"startBtn\" onclick=\"startGame()\">ابدأ اللعبة</button>\n</div>\n\n<div id=\"winScreen\">\n  <h2 id=\"winText\">فاز المقاتل!</h2>\n  <button id=\"restartBtn\" onclick=\"restartGame()\">العب مجدداً</button>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\nconst keys = {};\nconst mobileKeys = {};\n\ndocument.addEventListener('keydown', e => { keys[e.key.toLowerCase()] = true; });\ndocument.addEventListener('keyup', e => { keys[e.key.toLowerCase()] = false; });\n\ndocument.querySelectorAll('.dpad-btn').forEach(btn => {\n  const action = btn.dataset.action;\n  btn.addEventListener('touchstart', e => { e.preventDefault(); mobileKeys[action] = true; btn.classList.add('pressed'); }, {passive:false});\n  btn.addEventListener('touchend', e => { e.preventDefault(); mobileKeys[action] = false; btn.classList.remove('pressed'); }, {passive:false});\n  btn.addEventListener('mousedown', e => { mobileKeys[action] = true; btn.classList.add('pressed'); });\n  btn.addEventListener('mouseup', e => { mobileKeys[action] = false; btn.classList.remove('pressed'); });\n});\n\ndocument.querySelectorAll('.action-btn').forEach(btn => {\n  const action = btn.dataset.action;\n  btn.addEventListener('touchstart', e => { e.preventDefault(); triggerAction(action); }, {passive:false});\n  btn.addEventListener('mousedown', e => { triggerAction(action); });\n});\n\nfunction triggerAction(action) {\n  if (!gameRunning) return;\n  if (action === 'punch') player.attack('punch');\n  if (action === 'kick') player.attack('kick');\n  if (action === 'block') player.blocking = true;\n  if (action === 'special') player.attack('special');\n}\n\ndocument.addEventListener('touchend', e => {\n  const action = e.target.dataset && e.target.dataset.action;\n  if (action === 'block') player.blocking = false;\n});\ndocument.addEventListener('keyup', e => {\n  if (e.key.toLowerCase() === 'c') player.blocking = false;\n});\n\nlet gameRunning = false;\nlet round = 1;\nlet animId;\n\nconst FLOOR_Y = 0.6;\nconst GRAVITY = 0.015;\n\nclass Fighter {\n  constructor(x, color, isPlayer) {\n    this.x = x;\n    this.y = 0;\n    this.z = 0;\n    this.vx = 0;\n    this.vy = 0;\n    this.vz = 0;\n    this.color = color;\n    this.isPlayer = isPlayer;\n    this.hp = 100;\n    this.maxHp = 100;\n    this.blocking = false;\n    this.attackCooldown = 0;\n    this.hitFlash = 0;\n    this.attackAnim = 0;\n    this.attackType = null;\n    this.jumpCount = 0;\n    this.facing = isPlayer ? 1 : -1;\n    this.aiTimer = 0;\n    this.aiAction = null;\n    this.specialCooldown = 0;\n    this.particles = [];\n    this.stunTimer = 0;\n    this.comboCount = 0;\n    this.comboTimer = 0;\n  }\n\n  get screenX() { return W * 0.5 + this.x * 200 - this.z * 30; }\n  get screenY() { return H * FLOOR_Y - this.y * 200 - this.z * 15; }\n  get scale() { return 1 - this.z * 0.05; }\n\n  update(opponent) {\n    if (this.stunTimer > 0) { this.stunTimer--; return; }\n\n    if (this.isPlayer) this.handlePlayerInput(opponent);\n    else this.handleAI(opponent);\n\n    this.x += this.vx;\n    this.y += this.vy;\n    this.z += this.vz;\n\n    this.vy -= GRAVITY;\n    if (this.y <= 0) { this.y = 0; this.vy = 0; this.jumpCount = 0; }\n\n    this.x = Math.max(-3, Math.min(3, this.x));\n    this.z = Math.max(-2, Math.min(2, this.z));\n\n    this.vx *= 0.8;\n    this.vz *= 0.8;\n\n    if (this.attackCooldown > 0) this.attackCooldown--;\n    if (this.specialCooldown > 0) this.specialCooldown--;\n    if (this.hitFlash > 0) this.hitFlash--;\n    if (this.attackAnim > 0) this.attackAnim--;\n    if (this.comboTimer > 0) this.comboTimer--;\n    else this.comboCount = 0;\n\n    this.particles = this.particles.filter(p => p.life > 0);\n    this.particles.forEach(p => {\n      p.x += p.vx; p.y += p.vy; p.vy -= 0.3;\n      p.life--; p.size *= 0.92;\n    });\n\n    const dx = opponent.x - this.x;\n    this.facing = dx > 0 ? 1 : -1;\n  }\n\n  handlePlayerInput(opponent) {\n    const left = keys['a'] || keys['arrowleft'] || mobileKeys['left'];\n    "}]