[{"role":"user","content":"انشى ملف gg.html وسوي لعبة قتال 3D وفيها أزرار موبايل."},{"role":"assistant","content":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>لعبة القتال 3D</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: Arial, sans-serif; touch-action: none; }\n  #gameCanvas { display: block; width: 100vw; height: 100vh; }\n  #ui {\n    position: fixed; top: 0; left: 0; width: 100%; pointer-events: none; z-index: 10;\n  }\n  .health-bar-container {\n    display: flex; justify-content: space-between; align-items: flex-start;\n    padding: 10px 15px;\n  }\n  .fighter-info { width: 42%; }\n  .fighter-name {\n    color: #fff; font-size: 13px; font-weight: bold;\n    text-shadow: 1px 1px 3px #000; margin-bottom: 4px;\n  }\n  .health-bg {\n    width: 100%; height: 18px; background: #333;\n    border: 2px solid #555; border-radius: 3px; overflow: hidden;\n  }\n  .health-fill {\n    height: 100%; transition: width 0.2s;\n    background: linear-gradient(90deg, #ff2200, #ff6600);\n  }\n  #p2info .health-fill {\n    background: linear-gradient(90deg, #0066ff, #00ccff);\n    float: right;\n  }\n  .round-info {\n    text-align: center; color: #fff; font-size: 14px;\n    font-weight: bold; text-shadow: 0 0 8px #f90;\n  }\n  #timer {\n    font-size: 28px; color: #fff; text-align: center;\n    text-shadow: 0 0 10px #f90, 0 0 20px #f90;\n    font-weight: bold;\n  }\n  #message {\n    position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);\n    font-size: 48px; font-weight: bold; color: #fff;\n    text-shadow: 0 0 20px #f90, 0 0 40px #f00;\n    z-index: 20; display: none; text-align: center;\n    animation: pulse 0.5s infinite alternate;\n  }\n  @keyframes pulse { from{transform:translate(-50%,-50%) scale(1)} to{transform:translate(-50%,-50%) scale(1.1)} }\n  #controls {\n    position: fixed; bottom: 0; left: 0; width: 100%;\n    display: flex; justify-content: space-between;\n    padding: 10px 15px 20px; z-index: 15; pointer-events: none;\n  }\n  .dpad {\n    position: relative; width: 130px; height: 130px; pointer-events: all;\n  }\n  .dpad-btn {\n    position: absolute; width: 42px; height: 42px;\n    background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.4);\n    border-radius: 8px; display: flex; align-items: center; justify-content: center;\n    font-size: 18px; color: #fff; cursor: pointer; user-select: none;\n    transition: background 0.1s;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .dpad-btn:active, .dpad-btn.pressed { background: rgba(255,200,0,0.5); }\n  #btn-up    { top: 0;   left: 44px; }\n  #btn-down  { bottom: 0; left: 44px; }\n  #btn-left  { top: 44px; left: 0; }\n  #btn-right { top: 44px; right: 0; }\n  #btn-center { top: 44px; left: 44px; width: 42px; height: 42px;\n    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);\n    border-radius: 8px; }\n  .action-btns {\n    display: grid; grid-template-columns: 1fr 1fr;\n    gap: 10px; pointer-events: all; align-self: flex-end;\n  }\n  .action-btn {\n    width: 58px; height: 58px; border-radius: 50%;\n    border: 3px solid rgba(255,255,255,0.5);\n    display: flex; align-items: center; justify-content: center;\n    font-size: 11px; font-weight: bold; color: #fff;\n    cursor: pointer; user-select: none;\n    -webkit-tap-highlight-color: transparent;\n    transition: transform 0.1s, opacity 0.1s;\n  }\n  .action-btn:active { transform: scale(0.9); opacity: 0.7; }\n  #btn-punch  { background: rgba(255,80,0,0.7); }\n  #btn-kick   { background: rgba(200,0,200,0.7); }\n  #btn-block  { background: rgba(0,150,255,0.7); }\n  #btn-special { background: rgba(255,200,0,0.7); color: #000; }\n  #startScreen {\n    position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n    background: linear-gradient(135deg, #0a0a1a, #1a0a0a);\n    display: flex; flex-direction: column;\n    align-items: center; justify-content: center;\n    z-index: 100; color: #fff;\n  }\n  #startScreen h1 {\n    font-size: 42px; font-weight: bold; margin-bottom: 10px;\n    background: linear-gradient(90deg, #ff6600, #ffcc00, #ff6600);\n    -webkit-background-clip: text; -webkit-text-fill-color: transparent;\n    text-shadow: none; animation: glow 2s infinite;\n  }\n  @keyframes glow {\n    0%,100%{filter:brightness(1)} 50%{filter:brightness(1.5)}\n  }\n  #startScreen p { color: #aaa; margin-bottom: 30px; font-size: 14px; }\n  #startBtn {\n    padding: 15px 50px; font-size: 20px; font-weight: bold;\n    background: linear-gradient(90deg, #ff4400, #ff8800);\n    color: #fff; border: none; border-radius: 30px;\n    cursor: pointer; box-shadow: 0 0 20px #ff4400;\n    animation: btnPulse 1.5s infinite;\n  }\n  @keyframes btnPulse {\n    0%,100%{box-shadow:0 0 20px #ff4400} 50%{box-shadow:0 0 40px #ff8800}\n  }\n  #winScreen {\n    position: fixed; top: 0; left: 0; width: 100%; height: 100%;\n    background: rgba(0,0,0,0.85);\n    display: none; flex-direction: column;\n    align-items: center; justify-content: center;\n    z-index: 100; color: #fff;\n  }\n  #winScreen h2 { font-size: 36px; margin-bottom: 20px; color: #ffcc00; }\n  #winScreen p { font-size: 18px; color: #aaa; margin-bottom: 30px; }\n  #restartBtn {\n    padding: 12px 40px; font-size: 18px; font-weight: bold;\n    background: linear-gradient(90deg, #0066ff, #00ccff);\n    color: #fff; border: none; border-radius: 25px;\n    cursor: pointer; box-shadow: 0 0 15px #0066ff;\n  }\n</style>\n</head>\n<body>\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div class=\"health-bar-container\">\n    <div class=\"fighter-info\" id=\"p1info\">\n      <div class=\"fighter-name\">🔴 المقاتل 1</div>\n      <div class=\"health-bg\"><div class=\"health-fill\" id=\"p1health\" style=\"width:100%\"></div></div>\n    </div>\n    <div style=\"text-align:center;\">\n      <div id=\"timer\">60</div>\n      <div class=\"round-info\" id=\"roundInfo\">الجولة 1</div>\n    </div>\n    <div class=\"fighter-info\" id=\"p2info\" style=\"text-align:left;\">\n      <div class=\"fighter-name\" style=\"text-align:right;\">المقاتل 2 🔵</div>\n      <div class=\"health-bg\"><div class=\"health-fill\" id=\"p2health\" style=\"width:100%;float:right;\"></div></div>\n    </div>\n  </div>\n</div>\n\n<div id=\"message\"></div>\n\n<div id=\"controls\">\n  <div class=\"dpad\">\n    <div class=\"dpad-btn\" id=\"btn-up\">▲</div>\n    <div class=\"dpad-btn\" id=\"btn-left\">◀</div>\n    <div class=\"dpad-btn\" id=\"btn-center\"></div>\n    <div class=\"dpad-btn\" id=\"btn-right\">▶</div>\n    <div class=\"dpad-btn\" id=\"btn-down\">▼</div>\n  </div>\n  <div class=\"action-btns\">\n    <div class=\"action-btn\" id=\"btn-punch\">لكمة</div>\n    <div class=\"action-btn\" id=\"btn-kick\">ركلة</div>\n    <div class=\"action-btn\" id=\"btn-block\">دفاع</div>\n    <div class=\"action-btn\" id=\"btn-special\">⚡ خاص</div>\n  </div>\n</div>\n\n<div id=\"startScreen\">\n  <h1>⚔️ القتال 3D</h1>\n  <p>العب ضد الذكاء الاصطناعي</p>\n  <button id=\"startBtn\" onclick=\"startGame()\">ابدأ اللعبة</button>\n</div>\n\n<div id=\"winScreen\">\n  <h2 id=\"winText\">🏆 فزت!</h2>\n  <p id=\"winSub\">أحسنت!</p>\n  <button id=\"restartBtn\" onclick=\"restartGame()\">العب مجدداً</button>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// Game state\nlet gameRunning = false;\nlet gameTime = 60;\nlet timerInterval = null;\nlet round = 1;\nlet p1wins = 0;\nlet p2wins = 0;\n\n// Camera\nlet camAngle = 0;\nlet camDist = 420;\nlet camHeight = 200;\n\n// Arena\nconst ARENA_W = 600;\nconst ARENA_D = 400;\nconst FLOOR_Y = 0;\n\n// Fighter class\nclass Fighter {\n  constructor(x, z, color, isAI) {\n    this.x = x; this.y = 0; this.z = z;\n    this.vx = 0; this.vy = 0; this.vz = 0;\n    this.color = color;\n    this.isAI = isAI;\n    this.hp = 100;\n    this.maxHp = 100;\n    this.state = 'idle'; // idle, walk, jump, punch, kick, block, hurt, special, dead\n    this.stateTimer = 0;\n    this.facing = isAI ? -1 : 1;\n    this.animFrame = 0;\n    this.animTimer = 0;\n    this.blocking = false;\n    this.hitCooldown = 0;\n    this.specialCooldown = 0;\n    this.particles = [];\n    this.combo = 0;\n    this.comboTimer = 0;\n    this.aiTimer = 0;\n    this.aiAction = 'idle';\n    this.shadow = true;\n  }\n\n  update(dt, other) {\n    // Timers\n    if (this.stateTimer > 0) this.stateTimer -= dt;\n    if (this.hitCooldown > 0) this.hitCooldown -= dt;\n    if (this.specialCooldown > 0) this.specialCooldown -= dt;\n    if (this.comboTimer > 0) { this.comboTimer -= dt; if(this.comboTimer<=0) this.combo=0; }\n\n    // Gravity\n    if (this.y > 0 || this.vy > 0) {\n      this.vy -= 0.6;\n      this.y += this.vy;\n      if (this.y <= 0) { this.y = 0; this.vy = 0; if(this.state==='jump') this.state='idle'; }\n    }\n\n    // Movement\n    this.x += this.vx;\n    this.z += this.vz;\n    this.vx *= 0.8;\n    this.vz *= 0.8;\n\n    // Arena bounds\n    const hw = ARENA_W/2 - 30;\n    const hd = ARENA_D/2 - 30;\n    if (this.x < -hw) this.x = -hw;\n    if (this.x > hw) this.x = hw;\n    if (this.z < -hd) this.z = -hd;\n    if (this.z > hd) this.z = hd;\n\n    // Face opponent\n    const dx = other.x - this.x;\n    this.facing = dx > 0 ? 1 : -1;\n\n    // State machine\n    if (this.stateTimer <= 0 && this.state !== 'dead') {\n      if (this.state === 'punch' || this.state === 'kick' || this.state === 'special') {\n        this.state = 'idle';\n      }\n      if (this.state === 'hurt') this.state = 'idle';\n    }\n\n    // Attack hit detection\n    if ((this.state === 'punch' || this.state === 'kick' || this.state === 'special') &&\n        this.stateTimer > 0 && this.hitCooldown <= 0) {\n      const dist ="}]